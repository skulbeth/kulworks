# Kulworks environment variables.
#
# To set up on a machine: copy this to `.env.local` and fill in the values, OR
# (easiest) pull them straight from Vercel:
#     npm i -g vercel && vercel login && vercel link && vercel env pull .env.local
#
# The source of truth for real values is your Vercel project (Production).
# NEVER commit `.env.local` — it's git-ignored on purpose.

# --- Supabase (database + auth) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
DATABASE_URL=
DIRECT_URL=

# --- Resend (email) ---
RESEND_API_KEY=
RESEND_FROM=Kulworks <contact@kulworks.com>
QUOTE_NOTIFY_EMAIL=kulworksdesign@gmail.com
RESEND_AUDIENCE_ID=

# --- Cron protection (reminders + backup) ---
CRON_SECRET=

# --- Cloudflare Turnstile (bot protection) ---
# Local dev can use Cloudflare's always-pass TEST keys; prod uses the real ones.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Google Drive (auto client folders) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# --- SMS lead ping (optional; carrier email-to-SMS gateway) ---
NOTIFY_SMS=
