{
  "name": "kulworks",
  "version": "0.1.0",
  "private": true,
  "description": "Kulworks: multi-craft maker studio. Marketing + portfolio site.",
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:verify": "dotenv -e .env.local -- node scripts/verify-db.mjs",
    "admin:create": "dotenv -e .env.local -- node scripts/create-admin.mjs",
    "admin:check": "dotenv -e .env.local -- node scripts/check-login.mjs",
    "db:seed": "dotenv -e .env.local -- node scripts/seed-demo.mjs",
    "email:test": "dotenv -e .env.local -- node scripts/test-email.mjs",
    "google:auth": "dotenv -e .env.local -- node scripts/google-auth.mjs"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.3",
    "@prisma/client": "^6.19.3",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "next": "^16.0.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.14",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.10",
    "postcss": "^8",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.2"
  }
}
